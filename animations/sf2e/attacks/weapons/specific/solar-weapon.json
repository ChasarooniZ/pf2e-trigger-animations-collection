          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst weapongroup = inputs[0];\nconst isPhoton = inputs[1];\nconst file = isPhoton ? \"ggg-sfx.magic.fire.impact.flame.01.01\" :\"ggg-sfx.magic.occult.impact.general.02.01\";\nlet groupDelay=0;\nswitch (weapongroup){\n  case \"axe\":\n    groupDelay = 350;\n    break\n  case \"brawling\":\n    groupDelay = -200;\n    break\n  case \"club\":\n    groupDelay=0;\n    break\n  case \"flail\":\n    groupDelay=200;\n    break\n  case \"hammer\":\n    groupDelay=550;\n    break\n  case \"knife\":\n    groupDelay=0;\n    break\n  case \"pick\":\n    groupDelay=200;\n    break\n  case \"polearm\":\n    groupDelay=200;\n    break\n  case \"spear\":\n    groupDelay=0;\n    break\n  case \"sword\":\n    groupDelay=100;\n    break    \n}\nlet delay=1000 + (isPhoton ? -300: 0) + groupDelay;\nreturn [{type: \"text\", value: file}, {type:\"number\", value:delay}];"
