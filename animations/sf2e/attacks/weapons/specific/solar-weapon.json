      "inputs": {
        "script": {
          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst weapongroup = inputs[0];\nconst isPhoton = inputs[1];\nlet file = \"\";\nswitch (weapongroup){\n  case \"axe\":\n    file=\"jb2a.greataxe.melee.standard.white\";\n    break\n  case \"brawling\":\n    file=\"jb2a.unarmed_strike.magical.02.blue\";\n    break\n  case \"club\":\n    file=\"jb2a.greatclub.standard.white\";\n    break\n  case \"flail\":\n    file=\"jb2a.club.melee.01.white.4\";\n    break\n  case \"hammer\":\n    file=\"jb2a.maul.melee.standard.white\";\n    break\n  case \"knife\":\n    file=\"jb2a.dagger.melee.02.white\";\n    break\n  case \"pick\":\n    file=\"jb2a.warhammer.melee.01.white.4\";\n    break\n  case \"polearm\":\n    file=\"jb2a.halberd.melee.01.white.4\";\n    break\n  case \"spear\":\n    file=\"jb2a.spear.melee.01.white.2\";\n    break\n  case \"sword\":\n    file=\"jb2a.sword.melee.01.white.0\";\n    break\n}\nlet filter= '{\"hue\": -30, \"saturate\": 1}';\nif (!isPhoton)\n    filter = '{\"hue\": 180, \"saturate\": 1}';\nreturn [{type:\"text\", value: file}, {type: \"text\", value: filter}];"
        },
