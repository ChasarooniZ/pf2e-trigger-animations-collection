      "inputs": {
        "script": {
          "value": "let color = inputs[0];\n\n// 1. Colors\nlet rayFile;\nlet rayHue;\n\nif (color == \"Red\"){\n    rayFile = \"jb2a.scorching_ray.02.orange\"\n    rayHue = `{\"hue\": -15, \"brightness\": 0.9, \"saturate\": -0.1}`\n} else if (color == \"Orange\"){\n    rayFile = \"jb2a.scorching_ray.02.orange\"\n    rayHue = `{}`\n} else if (color == \"Yellow\"){\n    rayFile = \"jb2a.scorching_ray.02.orange\"\n    rayHue = `{\"hue\": 18}`\n} else if (color == \"Green\"){\n    rayFile = \"jb2a.scorching_ray.02.green\"\n    rayHue = `{}`\n} else if (color == \"Blue\"){\n    rayFile = \"jb2a.scorching_ray.02.blue\"\n    rayHue = `{}`\n} else if (color == \"Indigo\"){\n    rayFile = \"jb2a.scorching_ray.02.orange\"\n    rayHue = `{\"hue\": -160}`\n} else if (color == \"Violet\"){\n    rayFile = \"jb2a.scorching_ray.02.purple\"\n    rayHue = `{}`\n} else if (color == \"Intense\"){\n    rayFile = \"jb2a.scorching_ray.02.pink\"\n    rayHue = `{}`\n}\n\nreturn [\n  {type: \"text\", value: rayFile},\n  {type: \"text\", value: rayHue}\n];"
